generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  learner
  instructor
  admin
}

enum EnrollmentStatus {
  active
  completed
  dropped
}

enum WebhookStatus {
  pending
  delivered
  failed
  abandoned
}

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  courses          Course[]
  badges           Badge[]
  webhookEndpoints WebhookEndpoint[]
  auditLogs        AuditLog[]
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String       @unique
  name           String?
  passwordHash   String?
  role           Role         @default(learner)
  timezone       String       @default("UTC")
  disabled       Boolean      @default(false)
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  accounts      Account[]
  sessions      Session[]
  enrollments   Enrollment[]
  activities    Activity[]
  xpEvents      XpEvent[]
  userBadges    UserBadge[]
  streak        Streak?
  auditLogs     AuditLog[]    @relation("ActorAuditLogs")

  @@index([organizationId])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String
  title          String
  description    String?
  published      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lessons     Lesson[]
  enrollments Enrollment[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order       Int
  title       String
  content     String?
  xpReward    Int      @default(10)
  /// JSON: { requiresLessonIds?: string[], requiresXp?: number }
  gatingRule  Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities Activity[]
  progress   Progress[]

  @@unique([courseId, order])
  @@index([courseId])
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status    EnrollmentStatus @default(active)
  startedAt DateTime         @default(now())
  completedAt DateTime?

  progress Progress[]

  @@unique([userId, courseId])
  @@index([courseId])
}

model Activity {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId   String?
  lesson     Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  type       String
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
}

model Progress {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt  DateTime?
  score        Int?

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Badge {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String
  name           String
  description    String?
  /// JSON: { type: 'xp'|'streak'|'lessons', threshold: number }
  rule           Json
  createdAt      DateTime     @default(now())

  userBadges UserBadge[]

  @@unique([organizationId, slug])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model Streak {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  current            Int      @default(0)
  longest            Int      @default(0)
  lastActivityUtc    DateTime?
  lastActivityLocal  String?
  updatedAt          DateTime @updatedAt
}

model WebhookEndpoint {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  url            String
  secret         String
  events         String[]
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  deliveries WebhookDelivery[]

  @@index([organizationId])
}

model WebhookDelivery {
  id          String          @id @default(cuid())
  endpointId  String
  endpoint    WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event       String
  payload     Json
  status      WebhookStatus   @default(pending)
  attempts    Int             @default(0)
  lastError   String?
  nextAttempt DateTime?
  deliveredAt DateTime?
  createdAt   DateTime        @default(now())

  @@index([endpointId, status])
  @@index([status, nextAttempt])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUserId    String?
  actor          User?        @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)
  action         String
  target         String?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}
