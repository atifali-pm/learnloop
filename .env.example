DATABASE_URL="postgresql://learnloop:learnloop@localhost:5455/learnloop?schema=public"

AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Magic-link email (dev uses console transport; set these for real SMTP)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@learnloop.local"

# Sentry (optional)
SENTRY_DSN=""

# Shared secret for POST /api/webhooks/drain (used by cron)
WEBHOOK_DRAIN_SECRET="dev-drain-secret"
